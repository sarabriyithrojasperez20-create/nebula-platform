# OpenAI (Tutor IA)
OPENAI_API_KEY=

# PostgreSQL — elige UNA opción (no dejes localhost si no tienes Postgres instalado)

# Render (recomendado en local sin Postgres): External Database URL del panel
# DATABASE_URL=postgres://usuario:clave@dpg-xxxx.oregon-postgres.render.com/nombre_bd

# Postgres local en Windows (solo si el servicio está en marcha en el puerto 5432):
# DATABASE_URL=postgresql://nebula:nebula@localhost:5432/nebula

# Si DATABASE_URL no está definida, app.py usa el fallback de Render en db.py

# Pool de conexiones (opcional)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE=300
