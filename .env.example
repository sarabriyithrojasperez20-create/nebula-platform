# OpenAI (Tutor IA)
OPENAI_API_KEY=

# PostgreSQL — obligatorio para la capa de datos
DATABASE_URL=postgresql+psycopg2://nebula:nebula@localhost:5432/nebula

# Alternativa sin URL completa:
# POSTGRES_USER=nebula
# POSTGRES_PASSWORD=nebula
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=nebula

# Pool de conexiones (opcional)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE=300
