# Clave de sesión Flask (obligatoria en producción; genera una cadena aleatoria larga)
SECRET_KEY=
# Alternativa equivalente:
# FLASK_SECRET_KEY=

# OpenAI (Tutor IA)
OPENAI_API_KEY=

# Base de datos — elige UNA opción

# Desarrollo local sin instalar PostgreSQL (recomendado en Windows):
DATABASE_URL=sqlite:///instance/nebula.db

# Render (producción): External Database URL del panel
# DATABASE_URL=postgres://usuario:clave@dpg-xxxx.oregon-postgres.render.com/nombre_bd

# Postgres local (solo si tienes el servicio en el puerto 5432):
# DATABASE_URL=postgresql://nebula:nebula@localhost:5432/nebula

# Si no defines DATABASE_URL, la app usa SQLite en instance/nebula.db automáticamente

# Pool de conexiones (opcional)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE=300
